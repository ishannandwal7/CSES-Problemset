class DSU {
  vector<int>size,parent;
  public:
  int components;
  DSU(int n){
    size.resize(n,1);
    parent.resize(n);
    iota(begin(parent),end(parent),0);
    components = n;
  }
  int findParent(int node){
    if(parent[node]==node){return node;}
    return parent[node] = findParent(parent[node]);
  }
  void merge(int u,int v){
    int U = findParent(u);
    int V = findParent(v);
    if(U==V){return ;}
    if(size[U]<size[V]){
      size[V]+=size[U];
      parent[U]=V;
    }else{
      size[U]+=size[V];
      parent[V]=U;
    }
    --components;
    return ;
  }
};

void floyd_warshall(vector<vector<ll>>& dis) {
    int n = dis.size();
    const ll INF = 1e18;

    for(int k = 0; k < n; k++) {
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < n; j++) {
                if(dis[i][k] == INF || dis[k][j] == INF)
                    continue;

                dis[i][j] = min(dis[i][j],
                                dis[i][k] + dis[k][j]);
            }
        }
    }
    return ;
}

void solve() {
  int n,m,q;cin>>n>>m>>q;
  vector<vector<pair<int,int>>>adj(n+1);
  vector<vector<ll>>dis(n,vector<ll>(n,1e18));
  for(int i=0;i<n;++i){
    dis[i][i]=0;
  }
  for(int i=0;i<m;++i){
    int a,b;cin>>a>>b;
    ll c;cin>>c;
    adj[a].push_back({b,c});
    adj[b].push_back({a,c});
    dis[a-1][b-1] = min(dis[a-1][b-1],c);
    dis[b-1][a-1] = min(dis[b-1][a-1],c);
  }
  floyd_warshall(dis);
  while(q--){
    int a,b;cin>>a>>b;
    ll ans = dis[a-1][b-1];
    if(ans>=1e18){ans = -1;}
    cout<<ans<<"\n";
  }
  
  
  return ;
}
 
 
